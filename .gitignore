# Generated by Cargo
# will have compiled files and executables
debug
target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

.cargo/*

# Python
**__pycache__**
*.so
.venv/
.pytest_cache/
*.egg-info/
.ipynb_checkpoints/

# IDE state
.idea/
.vscode/

# Local-only working notes (Claude Code transcripts, scratch plans).
# These are author-private and must not be tracked.
.claude/
plans/

